# Production env — single reference for prod. Copy to .env when running backend against prod (e.g. local against Cloud SQL).
# On Cloud Run, use Secret Manager + --set-secrets instead of this file.

NODE_ENV=production
PORT=8080

# Cloud SQL (replace PUBLIC_IP and password)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@PUBLIC_IP:5432/interview_ai

JWT_ACCESS_SECRET=at-least-32-chars-from-openssl-rand-hex-32
JWT_REFRESH_SECRET=at-least-32-chars-from-openssl-rand-hex-32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_REPORT_MODEL=gemini-2.5-flash-lite
GEMINI_TOKEN_TTL=300

# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_TOKEN_TTL=300

# Production frontend origin(s), comma-separated
FRONTEND_URL=https://your-project.web.app

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_AGENT_NAME=

# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
